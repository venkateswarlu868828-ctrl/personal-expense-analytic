    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load dataset\n",
    "df = pd.read_csv(\"expenses\")\n",
    "\n",
    "# Display data\n",
    "print(\"Expense Data:\")\n",
    "print(df)\n",
    "\n",
    "# Total Expenses\n",
    "total_expense = df[\"Amount\"].sum()\n",
    "print(\"\\nTotal Expense:\", total_expense)\n",
    "\n",
    "# Category-wise Expenses\n",
    "category_expense = df.groupby(\"Category\")[\"Amount\"].sum()\n",
    "print(\"\\nCategory-wise Expense:\")\n",
    "print(category_expense)\n",
    "\n",
    "# Maximum Expense Category\n",
    "max_category = category_expense.idxmax()\n",
    "print(\"\\nHighest Spending Category:\", max_category)\n",
    "\n",
    "# Bar Chart\n",
    "plt.figure(figsize=(8,5))\n",
    "category_expense.plot(kind=\"bar\")\n",
    "plt.title(\"Category-wise Expenses\")\n",
    "plt.xlabel(\"Category\")\n",
    "plt.ylabel(\"Amount\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Pie Chart\n",
    "plt.figure(figsize=(6,6))\n",
    "category_expense.plot(kind=\"pie\", autopct=\"%1.1f%%\")\n",
    "plt.title(\"Expense Distribution\")\n",
    "plt.ylabel(\"\")\n",
    "plt.show()"
   ]
